APP_NAME="Durable Workflow Server"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_VERSION=2.0.0

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=durable_workflow
DB_USERNAME=root
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis

CACHE_STORE=redis

# Durable Workflow server configuration — see config/dw-contract.php for
# the full set. All operator-facing controls use the DW_ prefix. Legacy
# WORKFLOW_* / ACTIVITY_* names are still honored but log a deprecation
# warning at boot via `php artisan env:audit`.

DW_AUTH_PROVIDER=
DW_SERVER_KEY=
DW_AUTH_DRIVER=token
DW_AUTH_TOKEN=
DW_WORKER_TOKEN=
DW_OPERATOR_TOKEN=
DW_ADMIN_TOKEN=
DW_AUTH_BACKWARD_COMPATIBLE=true
DW_SIGNATURE_KEY=
DW_WORKER_SIGNATURE_KEY=
DW_OPERATOR_SIGNATURE_KEY=
DW_ADMIN_SIGNATURE_KEY=
DW_WORKER_POLL_TIMEOUT=30
DW_DEFAULT_NAMESPACE=default
DW_METRICS_WORKFLOW_TASK_FAILURE_TYPE_LIMIT=20

# Pin the supporting-service image tags used by docker-compose so a stack
# brought up months apart resolves to the same versions instead of drifting
# with the latest published `:8.0` / `:7-alpine` tag (TD-S058).
MYSQL_VERSION=8.0
REDIS_VERSION=7-alpine
